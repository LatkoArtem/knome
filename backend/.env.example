# === Knome Backend — Environment Variables ===
# Copy this file to .env and fill in the values.

# --- Security ---
# REQUIRED in production: generate with `python -c "import secrets; print(secrets.token_hex(32))"`
JWT_SECRET=knome-dev-secret-change-in-production

# --- Database ---
KUZU_DB_PATH=./data/knome.db
AUTH_DB_PATH=./data/auth.db

# --- LLM ---
# Local Ollama (default, free)
OLLAMA_BASE_URL=http://localhost:11434
LLM_MODEL=qwen2.5:7b
VISION_MODEL=llava

# --- Integrations (optional) ---
# Monobank personal API token.
# Get it: Monobank app → Settings → Other → API
MONOBANK_TOKEN=
